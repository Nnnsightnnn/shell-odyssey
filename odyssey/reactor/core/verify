#!/bin/bash

# Core Configuration Verification Script

CYAN='\033[0;36m'
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

echo ""
echo -e "${CYAN}╔════════════════════════════════════════════╗${NC}"
echo -e "${CYAN}║     CONFIGURATION VERIFICATION             ║${NC}"
echo -e "${CYAN}╚════════════════════════════════════════════╝${NC}"
echo ""

# Check if fixed file exists
if [[ ! -f "$SCRIPT_DIR/reactor_fixed.cfg" ]]; then
    echo -e "${RED}[ERROR]${NC} File 'reactor_fixed.cfg' not found."
    echo ""
    echo "Create the fixed configuration file first:"
    echo "  sed 's/old/new/' reactor.cfg > reactor_fixed.cfg"
    echo ""
    exit 1
fi

# Check if any CORRUPTED values remain
if grep -q "CORRUPTED" "$SCRIPT_DIR/reactor_fixed.cfg"; then
    echo -e "${RED}[FAILED]${NC} Configuration still contains corrupted values!"
    echo ""
    echo "The following lines still have CORRUPTED:"
    grep -n "CORRUPTED" "$SCRIPT_DIR/reactor_fixed.cfg"
    echo ""
    echo "Use sed to replace ALL corrupted values with correct ones."
    echo ""
    exit 1
fi

# Check if the values are correct
ERRORS=0

check_value() {
    local key="$1"
    local expected="$2"
    local actual=$(grep "^$key=" "$SCRIPT_DIR/reactor_fixed.cfg" | cut -d'=' -f2)

    if [[ "$actual" != "$expected" ]]; then
        echo -e "${RED}[WRONG]${NC} $key should be '$expected', got '$actual'"
        ((ERRORS++))
    else
        echo -e "${GREEN}[  OK  ]${NC} $key=$expected"
    fi
}

echo "Checking configuration values..."
echo ""
check_value "power_output" "85"
check_value "plasma_temperature" "100000000"
check_value "coolant_pressure" "250"
check_value "operational_mode" "NOMINAL"
echo ""

if [[ $ERRORS -gt 0 ]]; then
    echo -e "${RED}[FAILED]${NC} $ERRORS incorrect values found."
    echo ""
    echo "Compare with the reference file:"
    echo "  diff reactor.cfg.reference reactor_fixed.cfg"
    echo ""
    exit 1
fi

echo -e "${GREEN}╔════════════════════════════════════════════╗${NC}"
echo -e "${GREEN}║    CONFIGURATION REPAIR COMPLETE!          ║${NC}"
echo -e "${GREEN}╚════════════════════════════════════════════╝${NC}"
echo ""

# Create completion marker
touch "$SCRIPT_DIR/.complete"

cat << 'EOF'
    REPAIR STATUS:
    ──────────────
    All corrupted values have been successfully restored.

    You demonstrated:
    • Using sed to replace text patterns
    • Comparing files with reference data
    • Creating corrected output files

    ───────────────────────────────────────────────────────────
EOF
echo ""
echo "Next: Batch operations on cooling system files"
echo -e "  ${YELLOW}cd ../cooling${NC}"
echo ""
