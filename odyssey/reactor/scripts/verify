#!/bin/bash

# Scripts Verification Script

CYAN='\033[0;36m'
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
GAME_DIR="$(cd "$SCRIPT_DIR/../../.." && pwd)"

echo ""
echo -e "${CYAN}╔════════════════════════════════════════════╗${NC}"
echo -e "${CYAN}║     REPAIR SCRIPT VERIFICATION             ║${NC}"
echo -e "${CYAN}╚════════════════════════════════════════════╝${NC}"
echo ""

# Check if repair.sh exists
if [[ ! -f "$SCRIPT_DIR/repair.sh" ]]; then
    echo -e "${RED}[ERROR]${NC} File 'repair.sh' not found."
    echo ""
    echo "Copy the template and complete it:"
    echo "  cp repair_template.sh repair.sh"
    echo "  (edit repair.sh to complete the TODOs)"
    echo ""
    exit 1
fi

# Check if repair.sh is executable
if [[ ! -x "$SCRIPT_DIR/repair.sh" ]]; then
    echo -e "${RED}[ERROR]${NC} 'repair.sh' is not executable."
    echo ""
    echo "Make it executable:"
    echo "  chmod +x repair.sh"
    echo ""
    exit 1
fi

# Check if reactor_status.txt exists with correct content
if [[ ! -f "$SCRIPT_DIR/reactor_status.txt" ]]; then
    echo -e "${RED}[ERROR]${NC} File 'reactor_status.txt' not found."
    echo ""
    echo "Run your repair script first:"
    echo "  ./repair.sh"
    echo ""
    exit 1
fi

STATUS=$(cat "$SCRIPT_DIR/reactor_status.txt" | tr -d '[:space:]')
if [[ "$STATUS" != "ONLINE" ]]; then
    echo -e "${RED}[ERROR]${NC} reactor_status.txt does not contain 'ONLINE'."
    echo ""
    echo "Your script should write ONLINE to reactor_status.txt"
    echo "  echo \"ONLINE\" > reactor_status.txt"
    echo ""
    exit 1
fi

echo -e "${GREEN}[  OK  ]${NC} repair.sh exists"
echo -e "${GREEN}[  OK  ]${NC} repair.sh is executable"
echo -e "${GREEN}[  OK  ]${NC} reactor_status.txt contains ONLINE"
echo ""
echo -e "${GREEN}╔════════════════════════════════════════════════════════════╗${NC}"
echo -e "${GREEN}║            SECTOR 3: REACTOR COMPLETE!                     ║${NC}"
echo -e "${GREEN}╚════════════════════════════════════════════════════════════╝${NC}"
echo ""

# Create completion markers
touch "$SCRIPT_DIR/.complete"
touch "$SCRIPT_DIR/../.complete"

cat << 'EOF'
    ┌─────────────────────────────────────────────────────────────────┐
    │                                                                 │
    │  ★ ★ ★ ALL MAIN SECTORS COMPLETE! ★ ★ ★                        │
    │                                                                 │
    │  Skills mastered in this sector:                                │
    │  • sed - Text manipulation and substitution                     │
    │  • xargs - Batch operations on multiple files                   │
    │  • Shell scripting - Writing executable scripts                 │
    │  • chmod - Managing file permissions                            │
    │                                                                 │
    └─────────────────────────────────────────────────────────────────┘

    ═══════════════════════════════════════════════════════════════════

                    ╔═══════════════════════════════════╗
                    ║     REACTOR STATUS: ONLINE        ║
                    ║     NAVIGATION: RESTORED          ║
                    ║     COMMUNICATIONS: ACTIVE        ║
                    ║                                   ║
                    ║     ODYSSEY SYSTEMS: NOMINAL      ║
                    ╚═══════════════════════════════════╝

    Congratulations, Operator! You've restored critical ship systems
    using your terminal skills. The crew of the Odyssey owes you
    their lives.

    ARIA has begun rebooting and will take over automated systems.
    The ship is now on course to rendezvous with the rescue fleet.

    ═══════════════════════════════════════════════════════════════════

    BONUS CONTENT:
    Explore the BRIDGE for advanced challenges (optional):
      cd ~/shell-odyssey/odyssey/bridge

    Check your full progress:
      ~/shell-odyssey/scripts/check-progress.sh

EOF
echo ""
