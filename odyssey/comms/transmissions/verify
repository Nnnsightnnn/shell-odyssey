#!/bin/bash

# Transmissions Verification Script

CYAN='\033[0;36m'
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

echo ""
echo -e "${CYAN}╔════════════════════════════════════════════╗${NC}"
echo -e "${CYAN}║     TRANSMISSION COUNT VERIFICATION        ║${NC}"
echo -e "${CYAN}╚════════════════════════════════════════════╝${NC}"
echo ""

if [[ -z "$1" ]]; then
    echo -e "${RED}[ERROR]${NC} No count provided."
    echo ""
    echo "Usage: ./verify <count>"
    echo ""
    exit 1
fi

COUNT="$1"

if [[ "$COUNT" == "11" ]]; then
    echo -e "${GREEN}[CONFIRMED]${NC} Earth transmission count: 11"
    echo ""
    echo -e "${GREEN}╔════════════════════════════════════════════╗${NC}"
    echo -e "${GREEN}║    TRANSMISSION FILTERING COMPLETE!        ║${NC}"
    echo -e "${GREEN}╚════════════════════════════════════════════╝${NC}"
    echo ""

    # Create completion marker
    touch "$SCRIPT_DIR/.complete"

    cat << 'EOF'
    SIGNAL ANALYSIS:
    ────────────────
    You identified 11 transmissions from Earth among the noise.
    These transmissions contain the repair instructions we need.

    Unique sources detected:
    • EARTH - Mission Control (11 transmissions)
    • MARS_RELAY - Relay station (4 transmissions)
    • JUPITER_PROBE - Deep space probe
    • SATURN_STATION - Research station
    • PULSAR_J1903 - Pulsar timing beacon
    • NOISE - Various interference (many)

    ───────────────────────────────────────────────────────────
EOF
    echo ""
    echo "Excellent pipeline work! Now parse the signal data:"
    echo -e "  ${YELLOW}cd ../signals${NC}"
    echo ""
else
    echo -e "${RED}[INCORRECT]${NC} That's not the right count."
    echo ""
    echo "Hint: Use grep to find EARTH transmissions, then count them."
    echo ""
    echo "Try: grep \"EARTH\" signal_buffer.txt | wc -l"
    echo ""
    exit 1
fi
