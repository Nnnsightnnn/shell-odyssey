#!/bin/bash

# Decrypted Verification Script

CYAN='\033[0;36m'
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
GAME_DIR="$(cd "$SCRIPT_DIR/../../.." && pwd)"

echo ""
echo -e "${CYAN}╔════════════════════════════════════════════╗${NC}"
echo -e "${CYAN}║     REPAIR CODE VERIFICATION               ║${NC}"
echo -e "${CYAN}╚════════════════════════════════════════════╝${NC}"
echo ""

if [[ -z "$1" ]]; then
    echo -e "${RED}[ERROR]${NC} No code provided."
    echo ""
    echo "Usage: ./verify <code>"
    echo "Example: ./verify A-B-C-D-E-F"
    echo ""
    exit 1
fi

CODE=$(echo "$1" | tr '[:lower:]' '[:upper:]')

if [[ "$CODE" == "ALPHA-BETA-DELTA-GAMMA-SEVEN-NINE" ]]; then
    echo -e "${GREEN}[VERIFIED]${NC} Authorization code accepted!"
    echo ""
    echo -e "${GREEN}╔════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${GREEN}║          SECTOR 2: COMMUNICATIONS COMPLETE!                ║${NC}"
    echo -e "${GREEN}╚════════════════════════════════════════════════════════════╝${NC}"
    echo ""

    # Create completion marker
    touch "$SCRIPT_DIR/.complete"
    touch "$SCRIPT_DIR/../.complete"

    cat << 'EOF'
    ┌─────────────────────────────────────────────────────────────────┐
    │                                                                 │
    │  ★ COMMUNICATIONS SECTOR CLEARED ★                              │
    │                                                                 │
    │  Skills mastered:                                               │
    │  • Pipes (|) - Chaining commands together                       │
    │  • head/tail - Viewing portions of files                        │
    │  • sort/uniq - Ordering and deduplicating data                  │
    │  • cut/awk - Extracting specific fields                         │
    │  • Data pipelines - Complex multi-step processing               │
    │                                                                 │
    │  The repair instructions have been decoded! But to execute      │
    │  them, we need to access the REACTOR systems and run the        │
    │  actual repair scripts.                                         │
    │                                                                 │
    │  The reactor section requires shell scripting knowledge to      │
    │  automate the repair procedures.                                │
    │                                                                 │
    └─────────────────────────────────────────────────────────────────┘
EOF
    echo ""
    echo "Next sector: REACTOR"
    echo -e "  ${YELLOW}cd $GAME_DIR/odyssey/reactor${NC}"
    echo ""
else
    echo -e "${RED}[REJECTED]${NC} Invalid code sequence"
    echo ""
    echo "Hint: Sort the file by the first field (step number),"
    echo "      remove duplicates, extract the code fragments,"
    echo "      and join them with hyphens."
    echo ""
    echo "Pipeline: sort -t':' -k1 -n file | uniq | cut -d':' -f3"
    echo ""
    exit 1
fi
