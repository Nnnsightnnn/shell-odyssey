#!/bin/bash

# Signals Verification Script

CYAN='\033[0;36m'
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

echo ""
echo -e "${CYAN}╔════════════════════════════════════════════╗${NC}"
echo -e "${CYAN}║     MESSAGE ID VERIFICATION                ║${NC}"
echo -e "${CYAN}╚════════════════════════════════════════════╝${NC}"
echo ""

if [[ -z "$1" ]]; then
    echo -e "${RED}[ERROR]${NC} No message ID provided."
    echo ""
    echo "Usage: ./verify <message_id>"
    echo ""
    exit 1
fi

MSG_ID=$(echo "$1" | tr '[:lower:]' '[:upper:]')

if [[ "$MSG_ID" == "EC-4403-PRIORITY" ]]; then
    echo -e "${GREEN}[CONFIRMED]${NC} Priority message located: EC-4403-PRIORITY"
    echo ""
    echo -e "${GREEN}╔════════════════════════════════════════════╗${NC}"
    echo -e "${GREEN}║      SIGNAL PARSING COMPLETE!              ║${NC}"
    echo -e "${GREEN}╚════════════════════════════════════════════╝${NC}"
    echo ""

    # Create completion marker
    touch "$SCRIPT_DIR/.complete"

    cat << 'EOF'
    PARSING RESULTS:
    ────────────────
    You successfully extracted the priority message ID from
    the structured data using field extraction techniques.

    The CRITICAL priority message EC-4403-PRIORITY contains
    the core repair instructions. It has been forwarded to
    the decryption system.

    Skills demonstrated:
    • Parsing delimited data with cut
    • Filtering with grep
    • Building data pipelines

    ───────────────────────────────────────────────────────────
EOF
    echo ""
    echo "Proceed to final decryption:"
    echo -e "  ${YELLOW}cd ../decrypted${NC}"
    echo ""
else
    echo -e "${RED}[INCORRECT]${NC} Message ID not recognized: '$1'"
    echo ""
    echo "Hint: Find the line with SOURCE=EARTH and PRIORITY=CRITICAL"
    echo "      then extract the MESSAGE_ID (5th field)."
    echo ""
    echo "Try: grep \"EARTH\" transmission_log.csv | grep \"CRITICAL\""
    echo ""
    exit 1
fi
