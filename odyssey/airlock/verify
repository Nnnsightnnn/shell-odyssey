#!/bin/bash

# Airlock Mission Verification Script

CYAN='\033[0;36m'
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

echo ""
echo -e "${CYAN}╔════════════════════════════════════════════╗${NC}"
echo -e "${CYAN}║     VERIFICATION PROTOCOL INITIATED        ║${NC}"
echo -e "${CYAN}╚════════════════════════════════════════════╝${NC}"
echo ""

# Check if crew_count.txt exists
if [[ ! -f "$SCRIPT_DIR/crew_count.txt" ]]; then
    echo -e "${RED}[FAILED]${NC} File 'crew_count.txt' not found."
    echo ""
    echo "Create the file with the crew count:"
    echo "  echo <number> > crew_count.txt"
    echo ""
    exit 1
fi

# Read the answer
ANSWER=$(cat "$SCRIPT_DIR/crew_count.txt" | tr -d '[:space:]')

# Check if it's the correct number (24 crew members)
if [[ "$ANSWER" == "24" ]]; then
    echo -e "${GREEN}[SUCCESS]${NC} Crew count verified: 24 members"
    echo ""
    echo -e "${GREEN}╔════════════════════════════════════════════╗${NC}"
    echo -e "${GREEN}║      ORIENTATION TASK 1 COMPLETE!          ║${NC}"
    echo -e "${GREEN}╚════════════════════════════════════════════╝${NC}"
    echo ""

    # Create completion marker
    touch "$SCRIPT_DIR/.complete"

    echo "ARIA BACKUP: Excellent work, Operator. Your terminal access"
    echo "            is now verified. The crew is counting on you."
    echo ""
    echo "Your next task awaits in the equipment bay:"
    echo -e "  ${YELLOW}cd equipment_bay${NC}"
    echo ""
else
    echo -e "${RED}[FAILED]${NC} Incorrect crew count: '$ANSWER'"
    echo ""
    echo "Expected the total number of crew members."
    echo "Hint: Read manifest.txt carefully and count all entries."
    echo ""
    exit 1
fi
