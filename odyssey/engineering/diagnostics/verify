#!/bin/bash

# Diagnostics Verification Script

CYAN='\033[0;36m'
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
GAME_DIR="$(cd "$SCRIPT_DIR/../../.." && pwd)"

echo ""
echo -e "${CYAN}╔════════════════════════════════════════════╗${NC}"
echo -e "${CYAN}║     ENGINEERING AUTHORIZATION              ║${NC}"
echo -e "${CYAN}╚════════════════════════════════════════════╝${NC}"
echo ""

if [[ -z "$1" ]]; then
    echo -e "${RED}[ERROR]${NC} No authorization code provided."
    echo ""
    echo "Usage: ./verify <auth_code>"
    echo ""
    exit 1
fi

CODE=$(echo "$1" | tr '[:lower:]' '[:upper:]')

if [[ "$CODE" == "ENGINEERING_AUTH_7749" ]] || [[ "$CODE" == "7749" ]]; then
    echo -e "${GREEN}[AUTHORIZED]${NC} Engineering access granted"
    echo ""
    echo -e "${GREEN}╔════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${GREEN}║           SECTOR 1: ENGINEERING COMPLETE!                  ║${NC}"
    echo -e "${GREEN}╚════════════════════════════════════════════════════════════╝${NC}"
    echo ""

    # Create completion marker
    touch "$SCRIPT_DIR/.complete"
    touch "$SCRIPT_DIR/../.complete"

    cat << 'EOF'
    ┌─────────────────────────────────────────────────────────────────┐
    │                                                                 │
    │  ★ ENGINEERING SECTOR CLEARED ★                                 │
    │                                                                 │
    │  Skills mastered:                                               │
    │  • grep - Searching for patterns in files                       │
    │  • find - Locating files in directory trees                     │
    │  • wc   - Counting lines, words, and characters                 │
    │                                                                 │
    │  The navigation system failure has been diagnosed. However,     │
    │  to actually repair it, we need to decode the repair            │
    │  instructions that were transmitted from Earth before the       │
    │  failure.                                                       │
    │                                                                 │
    │  Proceed to COMMUNICATIONS to decode the transmissions.         │
    │                                                                 │
    └─────────────────────────────────────────────────────────────────┘
EOF
    echo ""
    echo "Next sector: COMMUNICATIONS"
    echo -e "  ${YELLOW}cd $GAME_DIR/odyssey/comms${NC}"
    echo ""
else
    echo -e "${RED}[ACCESS DENIED]${NC} Invalid authorization code"
    echo ""
    echo "Hint: Search the diagnostic reports for ENGINEERING_AUTH"
    echo ""
    echo "Try: grep -r \"AUTH\" *.rpt"
    echo ""
    exit 1
fi
