━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

LOCATION: Network Knowledge Archives, Deck 5
STATUS: Archive Access Granted
ACCESS: ALL CLEARANCE LEVELS

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

The Archives are quiet. Rows of data terminals glow softly in the dim light,
each one a gateway to decades of networking knowledge. The original network
engineers who built Earth's first internetworks left their wisdom here -
origin stories, mental models, hard-won insights.

Dr. Elena Vasquez, the station's historian, curated this collection. "Every
tool has a story," she wrote in her introduction. "Understanding where
something came from helps you understand how to use it."

    ┌─────────────────────────────────────────────────────────────────────┐
    │                                                                     │
    │  NEXUS: Welcome to the Archives, Specialist.                       │
    │                                                                     │
    │         Here you'll find the origin stories of your tools.         │
    │         Each one was created by humans solving real problems.      │
    │         Understanding their history will deepen your mastery.      │
    │                                                                     │
    │         The archives are organized by domain:                      │
    │                                                                     │
    │         • fundamentals/   - Basic networking tools                 │
    │         • troubleshooting/ - Diagnostic tools                      │
    │         • infrastructure/ - Docker and system tools                │
    │         • security/       - Isolation and protection               │
    │                                                                     │
    │         Read any .lore file to learn about a tool's history.       │
    │                                                                     │
    └─────────────────────────────────────────────────────────────────────┘

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

