#!/bin/bash
# verify - DNS Resolution mission completion checker

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

echo ""
echo -e "${CYAN}╔════════════════════════════════════════════════════════════════════════════════╗${NC}"
echo -e "${CYAN}║                    DNS RESOLUTION VERIFICATION                                 ║${NC}"
echo -e "${CYAN}╚════════════════════════════════════════════════════════════════════════════════╝${NC}"
echo ""

# Check if already completed
if [[ -f "$SCRIPT_DIR/.complete" ]]; then
    echo -e "${GREEN}[COMPLETED]${NC} This mission is already complete."
    echo "Proceed to the next module or run again to re-verify."
    echo ""
    exit 0
fi

# Check if dns_report.txt exists
if [[ ! -f "$SCRIPT_DIR/dns_report.txt" ]]; then
    echo -e "${RED}[INCOMPLETE]${NC} dns_report.txt not found."
    echo ""
    echo "Create a file called dns_report.txt with:"
    echo "  Line 1: IP address of 'server'"
    echo "  Line 2: IP address of 'api'"
    echo "  Line 3: Your DNS server IP"
    echo ""
    exit 1
fi

# Read the file
SERVER_IP=$(sed -n '1p' "$SCRIPT_DIR/dns_report.txt" | tr -d '[:space:]')
API_IP=$(sed -n '2p' "$SCRIPT_DIR/dns_report.txt" | tr -d '[:space:]')
DNS_IP=$(sed -n '3p' "$SCRIPT_DIR/dns_report.txt" | tr -d '[:space:]')

# Validate IP formats
if [[ ! "$SERVER_IP" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    echo -e "${RED}[INCOMPLETE]${NC} Line 1 does not look like a valid IP address."
    exit 1
fi

if [[ ! "$API_IP" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    echo -e "${RED}[INCOMPLETE]${NC} Line 2 does not look like a valid IP address."
    exit 1
fi

if [[ ! "$DNS_IP" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    echo -e "${RED}[INCOMPLETE]${NC} Line 3 does not look like a valid DNS server IP."
    exit 1
fi

# Verify reasonable values
echo -e "${GREEN}[VERIFIED]${NC} Server IP: $SERVER_IP"
echo -e "${GREEN}[VERIFIED]${NC} API IP: $API_IP"
echo -e "${GREEN}[VERIFIED]${NC} DNS Server: $DNS_IP"

# Success!
touch "$SCRIPT_DIR/.complete"

cat << 'EOF'

╔═══════════════════════════════════════════════════════════════════════════════╗
║                          MISSION COMPLETE                                     ║
╚═══════════════════════════════════════════════════════════════════════════════╝

NEXUS: "DNS mastery achieved, Specialist. You now understand how names
       become addresses in our network.

       Critical knowledge gained:
       - dig queries DNS and shows detailed results
       - dig +short gives just the answer
       - Private DNS knows internal names
       - External DNS (like Google's 8.8.8.8) only knows public names
       - DNS resolution != connectivity (you can resolve but not reach)

       This completes the Communications Bay training. You've mastered
       the fundamentals: IP addressing, connectivity testing, and DNS."

╔═══════════════════════════════════════════════════════════════════════════════╗
║                       MODULE 1 COMPLETE                                       ║
╚═══════════════════════════════════════════════════════════════════════════════╝

EOF

echo -e "${YELLOW}NEXT MODULE:${NC} cd ../../02-diagnostic && cat .scroll"
echo ""
