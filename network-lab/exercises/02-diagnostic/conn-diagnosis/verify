#!/bin/bash
# verify - Connection Diagnosis mission completion checker

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

echo ""
echo -e "${CYAN}╔════════════════════════════════════════════════════════════════════════════════╗${NC}"
echo -e "${CYAN}║                  CONNECTION DIAGNOSIS VERIFICATION                             ║${NC}"
echo -e "${CYAN}╚════════════════════════════════════════════════════════════════════════════════╝${NC}"
echo ""

# Check if already completed
if [[ -f "$SCRIPT_DIR/.complete" ]]; then
    echo -e "${GREEN}[COMPLETED]${NC} This mission is already complete."
    echo "Proceed to the next mission or run again to re-verify."
    echo ""
    exit 0
fi

# Check if diagnosis.txt exists
if [[ ! -f "$SCRIPT_DIR/diagnosis.txt" ]]; then
    echo -e "${RED}[INCOMPLETE]${NC} diagnosis.txt not found."
    echo ""
    echo "Create a file with:"
    echo "  Line 1: Failure layer for database (dns, ping, port, or protocol)"
    echo "  Line 2: Command to check if API port 5000 is open"
    echo ""
    exit 1
fi

# Read the file
LAYER=$(sed -n '1p' "$SCRIPT_DIR/diagnosis.txt" | tr -d '[:space:]' | tr '[:upper:]' '[:lower:]')
COMMAND=$(sed -n '2p' "$SCRIPT_DIR/diagnosis.txt" | tr '[:upper:]' '[:lower:]')

# Validate failure layer
if [[ "$LAYER" == "ping" ]] || [[ "$LAYER" == "connectivity" ]] || [[ "$LAYER" == "network" ]]; then
    echo -e "${GREEN}[VERIFIED]${NC} Correct! Database fails at the ping/connectivity layer."
else
    echo -e "${RED}[INCOMPLETE]${NC} '$LAYER' is not the correct failure layer."
    echo ""
    echo "Hint: DNS works (dig +short database returns an IP),"
    echo "      but you can't ping that IP. Which layer is that?"
    exit 1
fi

# Validate command (should contain nc and -z or netcat equivalent)
if [[ "$COMMAND" == *"nc"* ]] && [[ "$COMMAND" == *"-z"* ]] && [[ "$COMMAND" == *"5000"* ]]; then
    echo -e "${GREEN}[VERIFIED]${NC} Correct port check command: $COMMAND"
elif [[ "$COMMAND" == *"nc"* ]] && [[ "$COMMAND" == *"5000"* ]]; then
    echo -e "${GREEN}[VERIFIED]${NC} Port check command accepted: $COMMAND"
else
    echo -e "${RED}[INCOMPLETE]${NC} Command doesn't look like a port check."
    echo "Expected something like: nc -zv api 5000"
    exit 1
fi

# Success!
touch "$SCRIPT_DIR/.complete"

cat << 'EOF'

╔═══════════════════════════════════════════════════════════════════════════════╗
║                          MISSION COMPLETE                                     ║
╚═══════════════════════════════════════════════════════════════════════════════╝

NEXUS: "Systematic diagnosis is the mark of a skilled network operator.
       You've learned to:

       The Diagnostic Ladder:
       1. DNS    - Can you resolve the name? (dig)
       2. Ping   - Can you reach the IP? (ping)
       3. Port   - Is the service listening? (nc -zv)
       4. Protocol - Does the application respond? (curl)

       When database failed at 'ping', you knew immediately: it's a
       routing/connectivity issue, not DNS or the service itself.

       This systematic approach saves hours of guessing."

EOF

echo -e "${YELLOW}NEXT MISSION:${NC} cd ../packet-capture && cat .mission"
echo ""
