#!/bin/bash
# verify - Traffic Monitor mission completion checker

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

echo ""
echo -e "${CYAN}╔════════════════════════════════════════════════════════════════════════════════╗${NC}"
echo -e "${CYAN}║                  TRAFFIC MONITORING VERIFICATION                               ║${NC}"
echo -e "${CYAN}╚════════════════════════════════════════════════════════════════════════════════╝${NC}"
echo ""

# Check if already completed
if [[ -f "$SCRIPT_DIR/.complete" ]]; then
    echo -e "${GREEN}[COMPLETED]${NC} This mission is already complete."
    echo "Lab complete! Check your overall progress."
    echo ""
    exit 0
fi

# Check for monitoring_report.txt
if [[ ! -f "$SCRIPT_DIR/monitoring_report.txt" ]]; then
    echo -e "${RED}[INCOMPLETE]${NC} monitoring_report.txt not found."
    echo ""
    echo "Create a file with:"
    echo "  Line 1: Container with visibility into both networks"
    echo "  Line 2: PostgreSQL port number"
    echo "  Line 3: tcpdump filter for DNS"
    echo ""
    exit 1
fi

# Read answers
MONITOR_CONTAINER=$(sed -n '1p' "$SCRIPT_DIR/monitoring_report.txt" | tr -d '[:space:]' | tr '[:upper:]' '[:lower:]')
PG_PORT=$(sed -n '2p' "$SCRIPT_DIR/monitoring_report.txt" | tr -d '[:space:]')
DNS_FILTER=$(sed -n '3p' "$SCRIPT_DIR/monitoring_report.txt" | tr -d '[:space:]' | tr '[:upper:]' '[:lower:]')

CORRECT=0

# Validate monitor container
if [[ "$MONITOR_CONTAINER" == "monitor" ]] || [[ "$MONITOR_CONTAINER" == "api" ]]; then
    echo -e "${GREEN}[CORRECT]${NC} Both monitor and api have visibility into both networks"
    ((CORRECT++))
else
    echo -e "${RED}[WRONG]${NC} The 'monitor' (and 'api') containers are on both networks"
fi

# Validate PostgreSQL port
if [[ "$PG_PORT" == "5432" ]]; then
    echo -e "${GREEN}[CORRECT]${NC} PostgreSQL uses port 5432"
    ((CORRECT++))
else
    echo -e "${RED}[WRONG]${NC} PostgreSQL's default port is 5432"
fi

# Validate DNS filter
if [[ "$DNS_FILTER" == *"53"* ]]; then
    echo -e "${GREEN}[CORRECT]${NC} DNS filter includes port 53"
    ((CORRECT++))
else
    echo -e "${RED}[WRONG]${NC} DNS uses port 53, filter should be 'port 53'"
fi

if [[ $CORRECT -lt 3 ]]; then
    echo ""
    echo -e "${RED}[INCOMPLETE]${NC} Please correct your answers and try again."
    exit 1
fi

# Success!
touch "$SCRIPT_DIR/.complete"

cat << 'EOF'

╔═══════════════════════════════════════════════════════════════════════════════╗
║                          MISSION COMPLETE                                     ║
╚═══════════════════════════════════════════════════════════════════════════════╝

NEXUS: "Outstanding work, Specialist! You've mastered traffic monitoring -
       the ability to watch what crosses network boundaries.

       Monitoring strategy:
       1. Position monitors at zone boundaries
       2. Establish baseline traffic patterns
       3. Alert on anomalies
       4. Log for forensics

       What to watch for:
       - Unexpected connections (wrong ports/hosts)
       - High volume from single source
       - Failed connection attempts (TCP RST)
       - DNS queries revealing reconnaissance

       Remember: tcpdump sees EVERYTHING on the wire. Use it wisely."

╔═══════════════════════════════════════════════════════════════════════════════╗
║                       MODULE 4 COMPLETE                                       ║
╚═══════════════════════════════════════════════════════════════════════════════╝

╔═══════════════════════════════════════════════════════════════════════════════╗
║                    NETWORK LAB COMPLETE!                                      ║
╚═══════════════════════════════════════════════════════════════════════════════╝

NEXUS: "Congratulations, Specialist! You have completed all modules of the
       Network Learning Lab. You now possess the skills to:

       Module 1 - Network Basics:
       - Discover IP configuration
       - Test connectivity with ping
       - Resolve names with DNS

       Module 2 - Troubleshooting:
       - Diagnose connection failures systematically
       - Capture packets with tcpdump
       - Trace network paths

       Module 3 - Docker Networks:
       - Understand bridge networking
       - Create custom networks
       - Configure multi-network containers

       Module 4 - Security:
       - Verify network isolation
       - Design segmented architectures
       - Monitor cross-zone traffic

       The station's network is secure. Well done."

EOF

echo ""
echo "Check your overall progress: ../../../scripts/check-progress.sh"
echo ""
