#!/bin/bash
# verify - Isolation Verify mission completion checker

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

echo ""
echo -e "${CYAN}╔════════════════════════════════════════════════════════════════════════════════╗${NC}"
echo -e "${CYAN}║                  ISOLATION VERIFICATION                                        ║${NC}"
echo -e "${CYAN}╚════════════════════════════════════════════════════════════════════════════════╝${NC}"
echo ""

# Check if already completed
if [[ -f "$SCRIPT_DIR/.complete" ]]; then
    echo -e "${GREEN}[COMPLETED]${NC} This mission is already complete."
    echo "Proceed to the next mission or run again to re-verify."
    echo ""
    exit 0
fi

# Check for isolation_test.txt
if [[ ! -f "$SCRIPT_DIR/isolation_test.txt" ]]; then
    echo -e "${RED}[INCOMPLETE]${NC} isolation_test.txt not found."
    echo ""
    echo "Create a file with:"
    echo "  Line 1: Can client reach server? (yes/no)"
    echo "  Line 2: Can client reach database? (yes/no)"
    echo "  Line 3: Can API reach database? (yes/no)"
    echo "  Line 4: Gateway container name"
    echo ""
    exit 1
fi

# Read answers
CLIENT_SERVER=$(sed -n '1p' "$SCRIPT_DIR/isolation_test.txt" | tr -d '[:space:]' | tr '[:upper:]' '[:lower:]')
CLIENT_DB=$(sed -n '2p' "$SCRIPT_DIR/isolation_test.txt" | tr -d '[:space:]' | tr '[:upper:]' '[:lower:]')
API_DB=$(sed -n '3p' "$SCRIPT_DIR/isolation_test.txt" | tr -d '[:space:]' | tr '[:upper:]' '[:lower:]')
GATEWAY=$(sed -n '4p' "$SCRIPT_DIR/isolation_test.txt" | tr -d '[:space:]' | tr '[:upper:]' '[:lower:]')

# Validate answers
CORRECT=0

if [[ "$CLIENT_SERVER" == "yes" ]]; then
    echo -e "${GREEN}[CORRECT]${NC} Client can reach server (same network)"
    ((CORRECT++))
else
    echo -e "${RED}[WRONG]${NC} Client CAN reach server - they're on the same network"
fi

if [[ "$CLIENT_DB" == "no" ]]; then
    echo -e "${GREEN}[CORRECT]${NC} Client cannot reach database (network isolation)"
    ((CORRECT++))
else
    echo -e "${RED}[WRONG]${NC} Client CANNOT reach database - different networks"
fi

if [[ "$API_DB" == "yes" ]]; then
    echo -e "${GREEN}[CORRECT]${NC} API can reach database (multi-network)"
    ((CORRECT++))
else
    echo -e "${RED}[WRONG]${NC} API CAN reach database - it's on both networks"
fi

if [[ "$GATEWAY" == "api" ]]; then
    echo -e "${GREEN}[CORRECT]${NC} API is the gateway container"
    ((CORRECT++))
else
    echo -e "${RED}[WRONG]${NC} The gateway container is 'api' - it bridges both networks"
fi

if [[ $CORRECT -lt 4 ]]; then
    echo ""
    echo -e "${RED}[INCOMPLETE]${NC} Please correct the wrong answers and try again."
    exit 1
fi

# Success!
touch "$SCRIPT_DIR/.complete"

cat << 'EOF'

╔═══════════════════════════════════════════════════════════════════════════════╗
║                          MISSION COMPLETE                                     ║
╚═══════════════════════════════════════════════════════════════════════════════╝

NEXUS: "You've verified the network isolation in our lab. Trust but verify
       is the security mantra.

       Isolation status confirmed:
       - Frontend zone: client, server can communicate
       - Backend zone: database is protected
       - API: Bridges both zones with controlled access

       This architecture ensures:
       - Attackers on frontend can't reach database directly
       - All backend access is auditable through API
       - Blast radius of compromise is limited

       Network isolation is passive security - it works without configuration
       updates, without software patches, without user training."

EOF

echo -e "${YELLOW}NEXT MISSION:${NC} cd ../segmentation && cat .mission"
echo ""
